                },
                {
                    "name": "GIN_MODE",
                    "value": "release"
                },
                {
                    "name": "PG_HOST",
                    "value": "proxy-service.crsy0km663m8.ap-southeast-1.rds.amazonaws.com"
                },
                {
                    "name": "PG_DATABASE",
                    "value": "proxy_service"
                },
