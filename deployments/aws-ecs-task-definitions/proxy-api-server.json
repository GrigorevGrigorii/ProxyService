                {
                    "name": "PG_PASSWORD",
                    "valueFrom": "arn:aws:secretsmanager:ap-southeast-1:145026616839:secret:rds!db-06f97201-5282-40a7-86be-0e9f6f20f995-wdQyHT:password::"
                },
                {
                    "name": "PG_USER",
