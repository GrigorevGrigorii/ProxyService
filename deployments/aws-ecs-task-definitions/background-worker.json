{
    "family": "ProxyService-background-worker",
    "containerDefinitions": [
        {
            "name": "Main",
            "image": "",
            "cpu": 1024,
            "memory": 2048,
            "memoryReservation": 2048,
            "portMappings": [],
            "essential": true,
            "environment": [
                {
                    "name": "REDIS_MASTER_NAME",
                    "value": "!empty!"
                },
                {
                    "name": "REDIS_DATABASE",
                    "value": "0"
                },
                {
                    "name": "REDIS_PASSWORD",
                    "value": "!empty!"
                },
                {
                    "name": "REDIS_ADDRS",
                    "value": "proxy-service-prod-vleofz.serverless.apse1.cache.amazonaws.com:6379"
                },
                {
                    "name": "REDIS_ENABLE_TLS",
                    "value": "true"
                },
                {
                    "name": "MODE",
                    "value": "release"
                }
            ],
            "mountPoints": [],
            "volumesFrom": [],
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/aws/ecs/ProxyService/background-worker-6cf1",
                    "awslogs-region": "ap-southeast-1",
                    "awslogs-stream-prefix": "ecs"
                }
            },
            "systemControls": []
        }
    ],
    "executionRoleArn": "arn:aws:iam::145026616839:role/service-role/ecsTaskExecutionRole",
    "networkMode": "awsvpc",
    "volumes": [],
    "placementConstraints": [],
    "requiresCompatibilities": [
        "FARGATE"
    ],
    "cpu": "1024",
    "memory": "2048",
    "runtimePlatform": {
        "cpuArchitecture": "X86_64",
        "operatingSystemFamily": "LINUX"
    }
}